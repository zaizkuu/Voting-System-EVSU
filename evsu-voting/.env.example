# Supabase client configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase admin key (required for forgot-password API route)
SUPABASE_SERVICE_ROLE_KEY=

# Optional dedicated secret for signing reset OTP cookies
# If empty, SUPABASE_SERVICE_ROLE_KEY is used.
RESET_OTP_SECRET=

# Public app URL used to build auth redirects (must be your deployed HTTPS domain in production)
NEXT_PUBLIC_APP_URL=https://evsu-voting.vercel.app

# SMTP settings for password reset and registration confirmation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=
